{
  "name": "ao-presentation",
  "version": "1.0.0",
  "description": "Activation Oracles — Marp slide deck",
  "scripts": {
    "build:html": "marp slides.md --output dist/slides.html --allow-local-files",
    "build:pdf": "marp slides.md --output dist/slides.pdf --pdf --allow-local-files",
    "build:pptx": "marp slides.md --output dist/slides.pptx --pptx --allow-local-files",
    "build:all": "mkdir -p dist && npm run build:html && npm run build:pdf && npm run build:pptx",
    "watch": "marp slides.md --watch --output dist/slides.html --allow-local-files",
    "preview": "marp slides.md --preview --allow-local-files"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^3.4.0"
  }
}
